# AniList API client — create one at https://anilist.co/settings/developer
# The redirect URL registered there must EXACTLY match ANILIST_REDIRECT_URI below.
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=http://localhost:3000/api/anilist/callback

# Supabase Postgres connection string (Project Settings → Database → Connection string, URI form).
# Use the "Session pooler" URI. Account features are disabled until this is set.
DATABASE_URL=

# better-auth session secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Random 32+ byte secret used to encrypt stored AniList access tokens.
SESSION_SECRET=
