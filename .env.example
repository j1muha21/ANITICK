# AniList API client — create one at https://anilist.co/settings/developer
# The redirect URI registered there must EXACTLY match ANILIST_REDIRECT_URI below.
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Random 32+ byte secret used to encrypt the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=
